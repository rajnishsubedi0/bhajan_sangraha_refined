<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/bg_list_item"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Title & Decorative Icon Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <!-- Subtle Accent Icon Holder representing YouTube -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_circle_youtube">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_youtube"
                        android:tint="@color/accent_icon" />

                </FrameLayout>

                <TextView
                    android:id="@+id/dialog_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Play on YouTube"
                    android:textColor="@color/text_primary"
                    android:textSize="19dp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- Dialog Message containing description -->
            <TextView
                android:id="@+id/dialog_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:text="Watch or listen to this bhajan video/audio directly on YouTube."
                android:textColor="@color/text_secondary"
                android:textSize="15.5sp"
                android:lineSpacingMultiplier="1.25"
                android:fontFamily="sans-serif" />

            <!-- Action Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end">

                <!-- Cancel Button (Themed Text Button) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Close"
                    android:textColor="@color/text_secondary"
                    android:textSize="14.5sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp" />

                <!-- Action Confirm Button (Beautiful custom styled with accent color) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_youtube"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="Open YouTube"
                    android:textColor="@color/bg_list_item"
                    android:backgroundTint="@color/accent_icon"
                    android:textSize="14.5sp"
                    android:textStyle="bold"
                    app:cornerRadius="10dp"
                    app:rippleColor="#20FFFFFF" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
